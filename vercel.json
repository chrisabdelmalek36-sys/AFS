{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/refresh",
      "schedule": "0 4 * * *"
    }
  ],
  "functions": {
    "src/app/api/cron/refresh/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/lead/[id]/outreach/route.ts": {
      "maxDuration": 60
    }
  }
}

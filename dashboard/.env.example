# Dashboard reads the SAME database the lead engine writes to.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/afs_leads

# Optional: enables Google Directions waypoint optimization for routes.
# Leave blank — the route planner still works (local nearest-neighbour)
# and still exports to Google Maps mobile without a key.
GOOGLE_MAPS_API_KEY=

# --- Phase 3: outreach drafting ---
# Blank = strong TEMPLATE drafts (no AI, no cost). Add a key for
# Claude-personalised drafts.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Phase 3: compliance footer (required on every cold email) ---
AFS_COMPANY=AFS Trade
AFS_PHYSICAL_ADDRESS=AFS Trade, <street>, Cairo, Egypt
AFS_FROM_EMAIL=sales@afstrade.example
# Public URL of THIS dashboard, used to build the unsubscribe link.
PUBLIC_BASE_URL=http://localhost:3000
# Secret used to sign unsubscribe links (set any long random string).
UNSUBSCRIBE_SECRET=change-me-to-a-long-random-string

# ──────────────────────────────────────────────────────────
#  AFS Lead Engine — environment variables.
#  Copy this file to ".env.local" (or set them in Vercel's UI).
#  Nothing here is REQUIRED to launch with the 21 sample leads —
#  every external service has a safe key-less fallback.
# ──────────────────────────────────────────────────────────

# === Database (required) ============================================
DATABASE_URL=postgres://postgres:postgres@localhost:5432/afs_leads

# === Pipeline mode ===================================================
# sample = the 21 built-in Egyptian practice leads (no network)
# live   = real leads via FREE OpenStreetMap + FREE news (no key)
# unset  = live (OSM is key-less and free)
PIPELINE_MODE=live

# === Monthly API spend cap (USD) ====================================
# Only relevant if you add a Google Maps key below — OSM is free.
MONTHLY_BUDGET_USD=200

# === Google Maps (OPTIONAL — only for richer real-lead coverage) ====
# Without it OSM still finds Egyptian businesses for FREE.
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_COST_PER_1K=32
GOOGLE_PLACE_DETAILS_COST_PER_1K=17
MAX_PLACES_CALLS_PER_RUN=120

# === News sources ===================================================
NEWSAPI_KEY=
GDELT_ENABLED=true

# === Government / tender feeds (optional RSS URLs, comma-separated) =
GOV_FEED_URLS=

# === Anthropic Claude (OPTIONAL — personalised outreach drafts) =====
# Without a key, strong TEMPLATE drafts are used (no AI cost).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# === Resend email (OPTIONAL — actually sending the email sequence) ==
# Without RESEND_API_KEY + OUTREACH_LIVE_SEND=true, every send is
# SIMULATED (nothing leaves) — safe by default.
RESEND_API_KEY=
OUTREACH_LIVE_SEND=false

# === Compliance + branding ==========================================
AFS_COMPANY=AFS Trade
AFS_PHYSICAL_ADDRESS=AFS Trade, <street>, Cairo, Egypt
AFS_FROM_EMAIL=sales@afstrade.example
AFS_OWNER_EMAIL=                # where the 7AM digest is sent

# Public URL of the deployed dashboard (used to build the unsubscribe
# link in cold emails). Set this to your Vercel URL after deploy.
PUBLIC_BASE_URL=http://localhost:3000

# Secret for signing unsubscribe links (any long random string).
UNSUBSCRIBE_SECRET=change-me-to-a-long-random-string

# === Web scraping etiquette =========================================
ENRICH_WEBSITE_EMAILS=true
RESPECT_ROBOTS_TXT=true
HTTP_USER_AGENT=AFS-LeadEngine/1.0 (+contact: info@afstrade.example)

# === Schedules (when the worker is running long-running) ============
DAILY_CRON=0 6 * * *
OUTREACH_CRON=*/30 * * * *
DIGEST_CRON=0 7 * * *
TZ=Africa/Cairo

# === Vercel Cron secret (set automatically by Vercel) ===============
# Don't set manually unless you know what you're doing.
CRON_SECRET=

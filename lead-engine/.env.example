# ─────────────────────────────────────────────────────────────
# AFS Lead Engine — Phase 1 environment
# Copy this file to ".env" and fill in real values.
# Nothing here is required to run the SAMPLE-mode proof.
# ─────────────────────────────────────────────────────────────

# --- Database (Postgres) ---
# Local dev / the Docker Compose default both use this:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/afs_leads

# --- Pipeline mode ---
# sample = no external calls, uses built-in realistic Egyptian dataset (proof / demo)
# live   = calls real APIs below (requires keys)
PIPELINE_MODE=sample

# --- Monthly API budget cap (USD) ---
# The crawler tracks estimated spend and STOPS before exceeding this.
# You chose the $100–300/mo band; default cap is conservative.
MONTHLY_BUDGET_USD=200

# --- Google Maps Places API (Phase 1 primary source) ---
# Get a key: https://console.cloud.google.com/  → enable "Places API (New)"
# Billing: ~$32 / 1000 Nearby Search calls (Pro SKU). Budget cap protects you.
GOOGLE_MAPS_API_KEY=

# Cost assumptions used by the budget tracker (USD per 1000 calls).
GOOGLE_PLACES_COST_PER_1K=32
GOOGLE_PLACE_DETAILS_COST_PER_1K=17

# --- News sources (Phase 1 hot-lead detection) ---
# NewsAPI: https://newsapi.org/  (free tier exists; paid ~ from $0)
NEWSAPI_KEY=
# GDELT is free and keyless — leave NEWSAPI_KEY blank to use GDELT only.
GDELT_ENABLED=true

# --- Anthropic (Phase 3 — personalised outreach drafts) ---
# Blank = high-quality TEMPLATE drafts (no AI). Add a key for Claude.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Resend email (Phase 3 — email sequence sending) ---
# Blank OR OUTREACH_LIVE_SEND=false = every send is SIMULATED (safe,
# nothing actually leaves). Set BOTH to send real emails.
RESEND_API_KEY=
OUTREACH_LIVE_SEND=false
AFS_FROM_EMAIL=sales@afstrade.example

# --- Daily cron schedule (Cairo time) ---
# Default 06:00 Africa/Cairo. Cron format: m h dom mon dow
DAILY_CRON=0 6 * * *
# How often the email outreach queue is processed:
OUTREACH_CRON=*/30 * * * *
TZ=Africa/Cairo

# --- Crawl limits (protect budget & be a good web citizen) ---
MAX_PLACES_CALLS_PER_RUN=120
ENRICH_WEBSITE_EMAILS=true
RESPECT_ROBOTS_TXT=true
HTTP_USER_AGENT=AFS-LeadEngine/1.0 (+contact: info@afstrade.example)
